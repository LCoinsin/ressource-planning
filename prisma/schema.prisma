generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String   @default("[]") // JSON array ex: '["CAN_EDIT_GANTT","CAN_MANAGE_USERS"]'
  createdAt   DateTime @default(now())
  members     Member[]
}

model Member {
  id           String    @id @default(cuid())
  nom          String
  prenom       String
  role         String // rôle métier (Développeur Frontend, Chef de projet...)
  email        String?   @unique
  passwordHash String?
  isActive     Boolean   @default(true)
  isResource   Boolean   @default(true) // false for admins who only configure the app
  roleId       String?
  appRole      Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)
  dateArrivee  DateTime
  dateDepart   DateTime?
  createdAt    DateTime  @default(now())
  tasks        Task[]
}

model ProjectRequest {
  id           String    @id @default(cuid())
  contactName  String
  contactEmail String
  description  String
  desiredDate  DateTime?
  status       String    @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt    DateTime  @default(now())
}

model Technology {
  id        String   @id @default(cuid())
  nom       String   @unique
  couleur   String   // hex color
  iconName  String   // Lucide icon name
  customSvg String?  // raw SVG markup for custom icon
  createdAt DateTime @default(now())
  tasks     Task[]
}

model Project {
  id        String    @id @default(cuid())
  nom       String
  client    String
  status    String    @default("ACTIVE") // ACTIVE, PAUSED, DONE
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  sprints   Sprint[]
  tasks     Task[]
}

model Sprint {
  id          String   @id @default(cuid())
  titre       String
  description String?
  dateDebut   DateTime
  dateFin     DateTime
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime @default(now())
}

model Task {
  id           String      @id @default(cuid())
  titre        String
  type         String      @default("TASK") // TASK (kept for compat)
  dateDebut    DateTime
  dateFin      DateTime
  load         Float       @default(1.0)
  isCompleted  Boolean     @default(false)
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprintId     String?
  sprint       Sprint?     @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  members      Member[]    // N-N implicit join table
  technologyId String?
  technology   Technology? @relation(fields: [technologyId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
}
